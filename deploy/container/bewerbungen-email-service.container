# Quadlet for the Bewerbungstracker Email Service (SMTP/IMAP credential store).

[Unit]
Description=Bewerbungstracker Email Service
After=network-online.target
Wants=network-online.target

[Container]
Image=localhost/bewerbungen:latest
ContainerName=bewerbungen-email-service

Exec=email-service
Network=bewerbungen-net

PublishPort=127.0.0.1:8766:8766

Volume=/opt/bewerbungen-data:/app/data:z
Volume=/opt/bewerbungen-data/instance:/app/instance:z
Volume=/opt/bewerbungen-data/logs:/app/logs:z

EnvironmentFile=/etc/bewerbungen/bewerbungen.env

Environment=DATABASE_URL=sqlite:////app/data/instance/bewerbungstracker.db
Environment=FLASK_ENV=production
Environment=TZ=Europe/Berlin
Environment=BIND_HOST=0.0.0.0

Memory=256m
LogDriver=journald

[Service]
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
