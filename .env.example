# Bewerbungstracker – Environment Variables
# Copy this file to .env and fill in actual values for your environment.
#
# Two profiles are supported in parallel:
#   1) LOCAL DEVELOPMENT  → Mac/Linux laptop, all services on localhost
#   2) VPS / PRODUCTION   → IONOS VPS or similar, behind Apache+SSL
#
# Lines marked [LOCAL] / [VPS] indicate which profile they apply to. Lines
# without marker apply to both.

# ─── Flask runtime ──────────────────────────────────────────────────────
# [LOCAL] FLASK_ENV=development
# [VPS]   FLASK_ENV=production
FLASK_ENV=development
FLASK_APP=app.py

# Port for local Flask dev server (only when running app.py directly).
# Production uses gunicorn binding via systemd unit (see deploy/).
PORT=8080

# ─── Database ───────────────────────────────────────────────────────────
# Default puts SQLite in Flask instance/ folder (gitignored).
# For Postgres in production: DATABASE_URL=postgresql://user:pass@host:5432/db
DATABASE_URL=sqlite:///bewerbungstracker.db

# ─── Auth / JWT ─────────────────────────────────────────────────────────
# Generate a strong key per environment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Changing this invalidates all existing sessions (users have to re-login).
# DOES NOT affect data encryption – DEK stays valid (Envelope-Encryption).
JWT_SECRET_KEY=please-replace-with-strong-random-key

# Set to 'true' to require JWT for all /api/* requests (production default).
# 'false' = legacy mode (used in some early tests; do not use in production).
AUTH_REQUIRED=true

# Comma-separated list of origins allowed to call /api/*.
# [LOCAL] CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# [VPS]   CORS_ORIGINS=https://bewerbungen.wolfinisoftware.de,https://bewerbung.wolfinisoftware.de
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── App URL (used in confirmation/approval emails) ─────────────────────
# [LOCAL] APP_URL=http://localhost:8080
# [VPS]   APP_URL=https://bewerbungen.wolfinisoftware.de
APP_URL=http://localhost:8080

# ─── SMTP (Confirmation/Approval mails via Flask-Mail) ──────────────────
# Direct SMTP credentials (chmod 600 the .env file!). NOT used by
# email_service.py / imap_proxy.py – those have their own credential store.
# IONOS example:
MAIL_SERVER=smtp.ionos.de
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USERNAME=your.email@example.com
MAIL_PASSWORD=replace-with-your-smtp-password
MAIL_DEFAULT_SENDER=your.email@example.com

# ─── External services (optional) ───────────────────────────────────────
# Local URLs for IMAP-Proxy & Email-Service. Frontend auto-detects between
# http://127.0.0.1:876X (local) and Apache reverse-proxy (/imap-proxy etc.)
# based on window.location.hostname.
IMAP_PROXY_URL=http://127.0.0.1:8765

# Anthropic / Claude API (Phase 2 onwards)
CLAUDE_API_KEY=

# ─── Job-Discovery: Xing / LinkedIn / Stepstone (optional) ──────────────
# Alle Variablen sind optional. Leere Werte → Adapter ist no-op (returns []).
# Re-Run von scripts/seed_job_sources.py erstellt die Sources, ändert aber
# KEINE bestehenden Configs (idempotent by name). Konfig-Updates per UI/DB.

# RapidAPI JSearch — Multi-Source Aggregator (alle 3 Plattformen)
# Free-Tier: 2500 Requests/Monat. https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Xing RSS-Feed-URL (optional, falls vorhanden)
XING_RSS_URL=

# LinkedIn RSS — kein offizielles Feed, optional via 3rd-party (z.B. RSSHub)
LINKEDIN_RSS_URL=

# Stepstone RSS-Feed-URL (z.B. https://www.stepstone.de/jobs.rss?q=...)
STEPSTONE_RSS_URL=
