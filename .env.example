# Bewerbungstracker Production Environment Variables
# Copy this file to .env and fill in with actual production values

# Flask Configuration
# Set to 'production' for production deployments, 'development' for local testing
FLASK_ENV=production

# Flask Application File
FLASK_APP=app.py

# Database Configuration
# For production, use a PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:port/dbname
# For SQLite (development only):
DATABASE_URL=sqlite:///bewerbungstracker.db

# JWT Secret Key
# CRITICAL: Change this to a strong, randomly generated secret in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use the default value in production
JWT_SECRET_KEY=dev-secret-key-change-in-prod

# IMAP Proxy Configuration
# URL of the IMAP proxy service (typically running on localhost:8765)
IMAP_PROXY_URL=http://127.0.0.1:8765

# Claude API Configuration
# API key for Claude integration (Phase 2 onwards)
# Get your key from https://console.anthropic.com/
CLAUDE_API_KEY=

# Encryption Key
# CRITICAL: Used for encrypting sensitive data (e.g., IMAP credentials)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use the default value in production - must be a strong random key
ENCRYPTION_KEY=

# Database Encryption Key
# Used for encrypting sensitive database fields (user credentials, tokens)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left empty, a default key will be used (NOT RECOMMENDED for production)
# ⚠️ IMPORTANT: Keep this value consistent - changing it will break existing encrypted data
DATABASE_ENCRYPTION_KEY=

# IMAP Credential Storage
# IMPORTANT: IMAP credentials (username/password) are NOT stored in this .env file
# Instead, they are encrypted and stored per-user via the application API
# Users configure their IMAP credentials through the web UI or API endpoints
# All credentials are encrypted using the ENCRYPTION_KEY above before storage

# Port Configuration
# Port on which the application will listen (8080 is default for local development)
# For production behind a reverse proxy, this can remain unchanged
# For direct internet exposure, consider using port 443 (HTTPS) instead
PORT=8080

# Authentication Configuration
# Set to 'true' to enable JWT-based authentication
# Set to 'false' for legacy mode (no auth required)
# ⚠️ PRODUCTION CRITICAL: Change to 'true' for all production deployments
# When enabling in production, ensure frontend is updated to send Authorization headers
AUTH_REQUIRED=false

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# ⚠️ SECURITY WARNING: Default is empty (deny all) - you MUST explicitly configure this
# For development/testing (local only): http://localhost:3000,http://localhost:8080
# For production: specify exact origins like: https://yourdomain.com,https://api.yourdomain.com
# DO NOT use * in production - this allows requests from any origin
CORS_ORIGINS=

